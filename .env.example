# AtoZ Family — environment variables
#
# Copy to .env.local for local dev, or paste into Vercel project
# settings for preview + production. Every variable is documented
# below with whether it's required, what it enables, and what
# happens if it's missing.
#
# Boolean flags are checked as === "true".

# ──────────────────────────────────────────────────────────────────
# DEV BYPASS (local only — never set in production)
# ──────────────────────────────────────────────────────────────────

# When true, auth-context substitutes a mock user so every page
# renders without a real Firebase login. Used by the screenshot
# scripts and for quick local iteration without a Firebase project.
# NEVER ship this true to production — it would let anyone in.
NEXT_PUBLIC_DEV_BYPASS_AUTH=false

# Server-side guard: the mock-auth path refuses to run unless this
# is explicitly enabled, even when the NEXT_PUBLIC flag above is
# true. Belt + suspenders so a production build can't accidentally
# render signed-in.
ALLOW_DEV_AUTH_BYPASS=false

# ──────────────────────────────────────────────────────────────────
# FIREBASE (required for real auth)
# ──────────────────────────────────────────────────────────────────
# Without these, sign-in, sign-up, and reset-password fail. Dev
# bypass mode doesn't need them.
#
# Create a Firebase project → Project settings → General → Your apps
# → Web app. Copy the config values.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ──────────────────────────────────────────────────────────────────
# FIREBASE ADMIN (required for server-side session verification)
# ──────────────────────────────────────────────────────────────────
# Project settings → Service accounts → Generate new private key.
# The downloaded JSON has client_email, private_key, project_id.
# Paste the private_key as a single-line string with literal \n
# wherever there were newlines, OR wrap in quotes preserving them.

FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────────
# ANTHROPIC (optional — advisor + quick-log AI fallback)
# ──────────────────────────────────────────────────────────────────
# Without this, /api/advisor/suggest and /api/advisor/quick-log
# return 503. The UI hides the Advisor opt-in behind this check, so
# there's no noisy failure path — it simply isn't available.
#
# Get a key at https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────
# POSTGRES (optional — not required for MVP)
# ──────────────────────────────────────────────────────────────────
# Vercel Postgres connection string. /api/init-db silently 500s when
# missing; components/db-initializer catches it. Used only by a few
# legacy /api/lessons and /api/backups routes that aren't wired to
# the shipping UI. Safe to leave empty for v1 launch.

POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ──────────────────────────────────────────────────────────────────
# SENTRY (optional — error tracking)
# ──────────────────────────────────────────────────────────────────
# Without a DSN, Sentry initialization no-ops. With it set, client +
# server errors flow to the configured project. Recommended for
# production.
#
# https://sentry.io → Project → Settings → Client Keys → DSN

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ──────────────────────────────────────────────────────────────────
# VERCEL BLOB (optional — lesson photo upload backup for v2)
# ──────────────────────────────────────────────────────────────────
# Not wired into the shipping UI (photos go to IndexedDB per the
# local-first doctrine). Reserved for the v2 cloud-sync story.

BLOB_READ_WRITE_TOKEN=

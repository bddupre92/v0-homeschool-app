{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "AtoZ Family",
    "description": "Design tokens for the AtoZ Family homeschool app. Shape: calm, serene, low-contrast, low-chrome. Source of truth mirrored in app/globals.css.",
    "version": "1.0.0"
  },
  "color": {
    "background": {
      "linen":   { "value": "#faf6ee", "description": "Page background. The default canvas." },
      "linen-2": { "value": "#f3ecdb", "description": "Alt panel (slightly warmer)." },
      "linen-3": { "value": "#ebe3cd", "description": "Divider-adjacent fills." },
      "card":    { "value": "#ffffff", "description": "Cards and primary inline surfaces." }
    },
    "ink": {
      "base": { "value": "#1f2a22", "description": "Primary type, headlines." },
      "2":    { "value": "#3a453c", "description": "Secondary body." },
      "3":    { "value": "#6b6357", "description": "Muted body, captions." },
      "4":    { "value": "#8c8472", "description": "Eyebrows, timestamps, subtle hints." }
    },
    "rule": {
      "default": { "value": "#e3dcc5", "description": "Default hairline borders." },
      "strong":  { "value": "#d8cfb2", "description": "Emphasized dividers." }
    },
    "sage": {
      "base": { "value": "#7d9e7d", "description": "Calm-green base. Positive or ambient." },
      "d":    { "value": "#5e825e", "description": "Darker — secondary CTAs, hyperlinks." },
      "dd":   { "value": "#3d543d", "description": "Darkest — primary CTA fill." },
      "l":    { "value": "#cad8ca", "description": "Lighter — active fills." },
      "ll":   { "value": "#e4ebe4", "description": "Softest wash — hover states." }
    },
    "terracotta": {
      "base": { "value": "#d46e4d", "description": "Warm attention. Used sparingly." },
      "d":    { "value": "#a44830" },
      "l":    { "value": "#f2d3c7" },
      "ll":   { "value": "#fcf5f2" }
    },
    "honey": {
      "base": { "value": "#df8a27", "description": "Compliance countdown, honey-tone badges." },
      "d":    { "value": "#a8501c" },
      "l":    { "value": "#f3d8a3" },
      "ll":   { "value": "#fdf8ed" }
    },
    "brand": {
      "default": { "value": "#556b47", "description": "Family accent (overridable by user in Settings). Painted via --brand onto atoz-brand-mark and atoz-fab." }
    }
  },
  "kidColors": {
    "description": "Default palette for learner dots. Users can pick any of these or a custom hex when creating a kid.",
    "swatches": ["#d46e4d", "#7d9e7d", "#df8a27", "#6b8caf", "#9b7fbf", "#c07b7b"]
  },
  "typography": {
    "families": {
      "display": { "value": "Fraunces, ui-serif, Georgia, serif", "description": "Hero headlines, numbers, titles. Set variable-weight for tracking tightening." },
      "sans":    { "value": "Inter, ui-sans-serif, system-ui, sans-serif", "description": "All body copy, UI chrome." },
      "hand":    { "value": "Caveat, cursive", "description": "Pull-quotes only (atoz-quote class). Reserve for captured student voice." }
    },
    "scale": {
      "display-xl":  { "value": { "size": "48-56px", "weight": 300, "tracking": "-0.02em", "family": "display" }, "usage": "atoz-hero h1 on /today, /teach, /library." },
      "display-lg":  { "value": { "size": "32-40px", "weight": 400, "tracking": "-0.01em", "family": "display" }, "usage": "Kid pages, settings header." },
      "display-md":  { "value": { "size": "24px",    "weight": 500, "family": "display" }, "usage": "Section titles ('Today's lessons')." },
      "body":        { "value": { "size": "14-15px", "weight": 400, "family": "sans" },    "usage": "Default body." },
      "body-sm":     { "value": { "size": "13px",    "weight": 400, "family": "sans" },    "usage": "Secondary body, meta." },
      "eyebrow":     { "value": { "size": "11-12px", "weight": 600, "tracking": "0.14em", "transform": "uppercase", "family": "sans" }, "usage": "atoz-eyebrow — section label above headlines." },
      "caveat":      { "value": { "size": "18-22px", "weight": 400, "family": "hand" },    "usage": "atoz-quote — pull-quote from student." }
    }
  },
  "space": {
    "pad":         { "value": "20px", "description": "Card inner padding. Modulated by density." },
    "pad-compact": { "value": "14px" },
    "pad-spacious":{ "value": "28px" },
    "gap":         { "value": "16px", "description": "Default stack gap." },
    "gap-compact": { "value": "10px" },
    "gap-spacious":{ "value": "22px" }
  },
  "radius": {
    "sm":  { "value": "8px"  },
    "md":  { "value": "14px", "description": "Default cards, chips." },
    "lg":  { "value": "22px", "description": "Hero cards, sheets." },
    "pill":{ "value": "9999px", "description": "Pills, chip toggles, FAB." }
  },
  "shadow": {
    "soft":  { "value": "0 1px 0 rgba(45,58,45,0.02), 0 8px 24px -12px rgba(45,58,45,0.12)" },
    "hover": { "value": "0 1px 0 rgba(45,58,45,0.04), 0 14px 36px -14px rgba(45,58,45,0.22)" }
  },
  "density": {
    "description": "Three densities shift only padding, gap, and radius — never colors or type. Set on :root via data-density.",
    "options": ["compact", "comfortable", "spacious"]
  },
  "palette-intensity": {
    "description": "Three palette intensities shift ONLY the sage/terracotta/honey tokens. All other tokens stay stable. Set on :root via data-palette.",
    "options": ["soft", "default", "rich"]
  },
  "motion": {
    "quick":   { "value": "150ms ease",  "description": "Hover transitions, chip state changes." },
    "default": { "value": "250ms ease",  "description": "Sheet open/close, tabs." }
  }
}
